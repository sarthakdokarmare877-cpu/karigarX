// THREE.JS
let TH={};
function init3D(){
  const mount=document.getElementById('three-mount');
  if(!mount||!window.THREE)return;
  mount.innerHTML='';
  if(TH.animId)cancelAnimationFrame(TH.animId);
  const W=mount.clientWidth||520,H=500;
  const scene=new THREE.Scene();
  const camera=new THREE.PerspectiveCamera(40,W/H,0.1,100);
  camera.position.set(3,2.5,5);camera.lookAt(0,0.8,0);
  const renderer=new THREE.WebGLRenderer({antialias:true,alpha:true});
  renderer.setSize(W,H);renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.shadowMap.enabled=true;renderer.shadowMap.type=THREE.PCFSoftShadowMap;
  mount.appendChild(renderer.domElement);
  scene.add(new THREE.AmbientLight(0xfff8f0,0.9));
  const dir=new THREE.DirectionalLight(0xffffff,1.4);dir.position.set(5,8,6);dir.castShadow=true;
  dir.shadow.camera.left=-3;dir.shadow.camera.right=3;dir.shadow.camera.top=3;dir.shadow.camera.bottom=-3;scene.add(dir);
  const fill=new THREE.DirectionalLight(0xe8f4ff,0.5);fill.position.set(-4,2,-3);scene.add(fill);
  const gnd=new THREE.Mesh(new THREE.PlaneGeometry(20,20),new THREE.ShadowMaterial({opacity:0.08}));
  gnd.rotation.x=-Math.PI/2;gnd.position.y=-0.01;gnd.receiveShadow=true;scene.add(gnd);
  const cg=new THREE.Group();scene.add(cg);
  TH={scene,camera,renderer,cg,mount,animId:null,rotY:0,drag:false,prevX:0,autoRot:true};
  buildChair3D();
  const el=renderer.domElement;
  el.addEventListener('mousedown',e=>{TH.drag=true;TH.autoRot=false;TH.prevX=e.clientX;el.style.cursor='grabbing'});
  el.addEventListener('touchstart',e=>{TH.drag=true;TH.autoRot=false;TH.prevX=e.touches[0].clientX},{passive:true});
  window.addEventListener('mousemove',e=>{if(!TH.drag)return;TH.rotY+=(e.clientX-TH.prevX)*0.012;TH.prevX=e.clientX});
  window.addEventListener('touchmove',e=>{if(!TH.drag)return;TH.rotY+=(e.touches[0].clientX-TH.prevX)*0.012;TH.prevX=e.touches[0].clientX},{passive:true});
  window.addEventListener('mouseup',()=>{TH.drag=false;if(el)el.style.cursor='grab'});
  window.addEventListener('touchend',()=>TH.drag=false);
  function animate(){TH.animId=requestAnimationFrame(animate);if(TH.autoRot)TH.rotY+=0.006;TH.cg.rotation.y=TH.rotY;renderer.render(scene,camera);}
  animate();
}
function buildChair3D(){
  const g=TH.cg;if(!g||!window.THREE)return;
  while(g.children.length)g.remove(g.children[0]);
  const fc=parseInt(ST.config.frameColor.replace('#',''),16);
  const cc=parseInt(ST.config.cushionColor.replace('#',''),16);
  const isWood=['Teak Wood','Sheesham','Walnut'].includes(ST.config.material);
  const rough=ST.config.finish==='Glossy'?0.15:ST.config.finish==='Satin'?0.4:0.85;
  const FM=new THREE.MeshStandardMaterial({color:fc,roughness:rough,metalness:isWood?0.05:0.65});
  const CM=new THREE.MeshStandardMaterial({color:cc,roughness:0.95,metalness:0});
  const lH=ST.config.sh/100,sW=ST.config.w/100,sD=ST.config.d/100,tH=ST.config.h/100,bH=tH-lH-0.1;
  function mesh(geo,mat,x,y,z,rx,ry,rz){const m=new THREE.Mesh(geo,mat);m.position.set(x,y,z);if(rx)m.rotation.x=rx;if(ry)m.rotation.y=ry;if(rz)m.rotation.z=rz;m.castShadow=true;m.receiveShadow=true;g.add(m);return m;}
  const type=ST.config.type;
  if(type==='dining'){
    mesh(new THREE.BoxGeometry(sW,0.06,sD),FM,0,lH,0);
    mesh(new THREE.BoxGeometry(sW-0.02,0.08,sD-0.02),CM,0,lH+0.04,0);
    mesh(new THREE.BoxGeometry(sW,bH,0.07),CM,0,lH+0.1+bH/2,-sD/2+0.05);
    mesh(new THREE.BoxGeometry(sW+0.02,bH+0.02,0.05),FM,0,lH+0.1+bH/2,-sD/2+0.03);
    [[sW/2-0.04,-sD/2+0.04],[-(sW/2-0.04),-sD/2+0.04],[sW/2-0.04,sD/2-0.04],[-(sW/2-0.04),sD/2-0.04]].forEach(([x,z])=>{mesh(new THREE.BoxGeometry(0.04,lH,0.04),FM,x,lH/2,z);});
    mesh(new THREE.BoxGeometry(sW-0.12,0.03,0.03),FM,0,lH*0.38,sD/2-0.04);
  } else if(type==='accent'){
    mesh(new THREE.CylinderGeometry(sW*0.52,sW*0.48,0.1,16),CM,0,lH,0);
    mesh(new THREE.CylinderGeometry(sW*0.54,sW*0.5,0.06,16),FM,0,lH-0.01,0);
    const pts=[];for(let i=0;i<=8;i++){const t=i/8;pts.push(new THREE.Vector2(sW*0.5*(1-t*0.15),t*bH*0.8));}
    const lat=new THREE.LatheGeometry(pts,18,Math.PI*0.55,Math.PI*1.3);const bk=new THREE.Mesh(lat,CM);bk.position.set(0,lH+0.05,0);bk.castShadow=true;g.add(bk);
    [[1,1],[-1,1],[1,-1],[-1,-1]].forEach(([xs,zs])=>{const leg=new THREE.Mesh(new THREE.CylinderGeometry(0.025,0.02,lH*1.1,8),FM);leg.position.set(xs*sW*0.36,lH*0.5,zs*sW*0.36);leg.rotation.z=xs>0?-0.18:0.18;leg.rotation.x=zs>0?0.18:-0.18;leg.castShadow=true;g.add(leg);});
  } else if(type==='lounge'){
    const lw=sW*1.35,ld=sD*1.2;
    mesh(new THREE.BoxGeometry(lw,0.1,ld),CM,0,lH*0.55,0);
    mesh(new THREE.BoxGeometry(lw+0.02,0.07,ld+0.02),FM,0,lH*0.55-0.02,0);
    const bkh=bH*0.32;const bk=new THREE.Mesh(new THREE.BoxGeometry(lw,bkh,0.1),CM);bk.rotation.x=-0.2;bk.position.set(0,lH*0.55+0.1+bkh*0.42,-ld/2+0.06);bk.castShadow=true;g.add(bk);
    [-1,1].forEach(s=>{mesh(new THREE.BoxGeometry(0.08,0.07,ld*0.75),FM,s*lw/2,lH*0.55+0.1+0.035,-ld*0.1);});
    mesh(new THREE.BoxGeometry(lw+0.06,lH*0.55,ld+0.06),FM,0,lH*0.275,0);
  } else if(type==='barstool'){
    const bLH=lH*1.75;
    mesh(new THREE.CylinderGeometry(sW*0.46,sW*0.44,0.08,16),CM,0,bLH,0);
    mesh(new THREE.CylinderGeometry(sW*0.48,sW*0.46,0.05,16),FM,0,bLH-0.01,0);
    const tor=new THREE.Mesh(new THREE.TorusGeometry(sW*0.32,0.022,8,24),FM);tor.rotation.x=Math.PI/2;tor.position.y=bLH*0.38;tor.castShadow=true;g.add(tor);
    for(let i=0;i<4;i++){const a=(i/4)*Math.PI*2;mesh(new THREE.CylinderGeometry(0.022,0.018,bLH,8),FM,Math.cos(a)*sW*0.33,bLH/2,Math.sin(a)*sW*0.33);}
  }
  const box=new THREE.Box3().setFromObject(g);const c=box.getCenter(new THREE.Vector3());g.position.sub(c);g.position.y+=box.getSize(new THREE.Vector3()).y/2;
}
function rebuild3D(){if
