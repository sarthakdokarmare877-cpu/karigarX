// NAV
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const p=document.getElementById(id);
  if(p)p.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}
function goUser(){document.getElementById('main-nav').style.display='flex';showPage('home-page');renderHomeCats();}
function goVendor(){document.getElementById('main-nav').style.display='flex';showPage('vendor-page');renderVendorProducts();}
function goHome(){hideStepBar();showPage('home-page');}
function startDesign(){showPage('step1-page');showStepBar(1);renderStep1Cats();}
function goStep1(){showPage('step1-page');showStepBar(1);}
function goStep2(){
  if(!ST.selectedCategory){showToast('Please select a category first');return;}
  if(ST.selectedCategory!=='chair'){showToast('🚧 More categories coming soon!');ST.selectedCategory='chair';}
  showPage('step2-page');showStepBar(2);renderChairTypes();
}
function goStep3(){
  if(!ST.selectedChairType){showToast('Please select a chair type');return;}
  showPage('step3-page');showStepBar(3);renderDesigns();
}
function goStep4(){
  if(!ST.selectedDesign){showToast('Please select a design');return;}
  showPage('step4-page');showStepBar(4);
  document.getElementById('step4-title').textContent='Customize: '+ST.selectedDesign.name;
  setTimeout(()=>initConfigurator(),80);
}
function goStep5(){showPage('step5-page');showStepBar(5);}
function goStep6(){showPage('step6-page');showStepBar(6);startAIAnalysis();}

function showStepBar(step){
  ST.step=step;
  document.getElementById('step-bar').style.display='flex';
  for(let i=1;i<=6;i++){
    const d=document.getElementById('sd'+i),n=document.getElementById('sn'+i),l=document.getElementById('sl'+i);
    if(!d)continue;
    d.className='step-dot'+(i<step?' done':i===step?' active':'');
    if(n)n.className='step-name'+(i===step?' active':'');
    if(l)l.className='step-line'+(i<step?' done':'');
  }
}
function hideStepBar(){document.getElementById('step-bar').style.display='none';}

// RENDERS
function renderHomeCats(){
  const g=document.getElementById('home-cat-grid');if(!g)return;
  g.innerHTML=CATEGORIES.map(c=>`<div class="cat-card" onclick="ST.selectedCategory='${c.id}';startDesign()"><span class="cat-icon">${c.icon}</span><div class="cat-name">${c.name}</div><div class="cat-desc">${c.desc}</div></div>`).join('');
}
function renderStep1Cats(){
  const g=document.getElementById('step1-cat-grid');if(!g)return;
  g.innerHTML=CATEGORIES.map(c=>`<div class="cat-card${ST.selectedCategory===c.id?' selected':''}" onclick="selectCat('${c.id}',this)"><span class="cat-icon">${c.icon}</span><div class="cat-name">${c.name}</div><div class="cat-desc">${c.desc}</div></div>`).join('');
  document.getElementById('step1-next').disabled=!ST.selectedCategory;
}
function selectCat(id,el){
  ST.selectedCategory=id;
  document.querySelectorAll('#step1-cat-grid .cat-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('step1-next').disabled=false;
  if(id!=='chair')showToast('🚧 More categories coming soon!');
}
